{
  "name": "vibesync",
  "private": true,
  "version": "1.0.0",
  "description": "Local coding agent context handoff for Claude Code, Codex, Antigravity CLI, and OpenCode.",
  "author": "VibeSync contributors",
  "license": "MIT",
  "homepage": "https://github.com/GordonBai/vibesync",
  "type": "module",
  "main": "main-electron.cjs",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "vite build",
    "build:desktop": "vite build && electron-builder --dir",
    "package:zip": "vite build && electron-builder --mac --publish=never",
    "lint": "eslint .",
    "test": "node --test tests/*.test.cjs",
    "test:terminal-context": "node --test tests/terminal-context.test.cjs",
    "test:hotkey-sync": "node --test tests/hotkey-sync.test.cjs",
    "diagnose:hotkey": "node diagnose-hotkey.cjs",
    "preview": "vite preview",
    "desktop": "concurrently \"npm run dev\" \"electron . --dev\""
  },
  "build": {
    "appId": "com.vibesync.app",
    "productName": "VibeSync",
    "mac": {
      "target": "zip",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "files": [
      "dist/**/*",
      "main-electron.cjs",
      "terminal-context.cjs",
      "hotkey-sync.cjs",
      "diagnose-hotkey.cjs",
      "preload.cjs",
      "logger.cjs",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend"
      }
    ]
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
