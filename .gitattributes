# Normalize line endings for all text files on commit.
* text=auto

# Force LF for cross-platform shell, JS, and Python sources.
*.sh        text eol=lf
*.py        text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.cjs       text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Treat known binary assets as binary (no diff/eol munging).
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.icns      binary
*.ico       binary
*.zip       binary
*.dmg       binary
*.woff      binary
*.woff2     binary
